# Server (Phase 1) - Configuration Template
# Copy this file to config.env and fill in your actual values

# Server Port
PORT=3000

# Node Environment
NODE_ENV=development

# MongoDB Connection String
# For local: mongodb://localhost:27017/aiinterviewer
# For Atlas: mongodb+srv://username:password@cluster.mongodb.net/aiinterviewer
MONGO_CONN_STR=mongodb+srv://username:password@cluster.mongodb.net/aiinterviewer

# JWT Secret Key (use a strong, random string)
JWT_SECRET_STRING=your_super_secret_jwt_key_change_this_in_production

# Email Configuration (Optional - for future use)
SENDING_EMAIL=your_email@gmail.com
SENDING_EMAIL_PASSWORD=your_app_password

# Frontend URL (for CORS and links)
FRONTEND_URL=http://localhost:5173

# Application Settings
APP_NAME=AI Interviewer Phase 1
APP_VERSION=1.0.0
